# ServiceNow connection for the Syncrona CLI.
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and must never be committed.
#
# Preferred alternative: run `syncrona login`, which stores credentials
# encrypted in ~/.syncrona and removes the need for a local .env.

SN_INSTANCE=your-instance.service-now.com
SN_USER=your-username
SN_PASSWORD=your-password
